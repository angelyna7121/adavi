generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model analytics_events {
  id         Int      @id @default(autoincrement())
  user_id    Int?
  event_name String
  metadata   String?
  created_at DateTime @default(now()) @db.Timestamp(6)
  users      users?   @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "analytics_events_user_id_users_id_fk")
}

model income_strategies {
  id                      Int      @id @default(autoincrement())
  user_id                 Int
  title                   String
  province                String   @default("ON")
  corporate_profit        Int      @default(0)
  desired_cash_withdrawal Int      @default(0)
  grip_balance            Int?
  wants_cpp_rrsp          String?
  prefer_simple           Boolean  @default(false)
  salary_recommendation   Int?
  dividend_recommendation Int?
  blended_note            String?
  created_at              DateTime @default(now()) @db.Timestamp(6)
  users                   users    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model net_worth_items {
  id                   Int                  @id @default(autoincrement())
  statement_id         Int
  user_id              Int
  type                 String
  category             String
  name                 String
  amount               Int                  @default(0)
  notes                String?
  created_at           DateTime             @default(now()) @db.Timestamp(6)
  updated_at           DateTime             @default(now()) @db.Timestamp(6)
  net_worth_statements net_worth_statements @relation(fields: [statement_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                users                @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model net_worth_statements {
  id                Int               @id @default(autoincrement())
  user_id           Int
  title             String            @default("My Net Worth")
  total_assets      Int               @default(0)
  total_liabilities Int               @default(0)
  net_worth         Int               @default(0)
  created_at        DateTime          @default(now()) @db.Timestamp(6)
  updated_at        DateTime          @default(now()) @db.Timestamp(6)
  net_worth_items   net_worth_items[]
  users             users             @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model reports {
  id           Int      @id @default(autoincrement())
  user_id      Int
  report_type  String
  title        String
  reference_id Int?
  status       String   @default("generated")
  created_at   DateTime @default(now()) @db.Timestamp(6)
  users        users    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model scenarios {
  id                 Int      @id @default(autoincrement())
  title              String
  corporate_revenue  Int      @default(0)
  corporate_expenses Int      @default(0)
  salary_amount      Int      @default(0)
  dividend_amount    Int      @default(0)
  province           String   @default("ON")
  created_at         DateTime @default(now()) @db.Timestamp(6)
  user_id            Int?
  updated_at         DateTime @default(now()) @db.Timestamp(6)
  users              users?   @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "scenarios_user_id_users_id_fk")
}

model session {
  sid    String   @id @db.VarChar
  sess   Json     @db.Json
  expire DateTime @db.Timestamp(6)

  @@index([expire], map: "IDX_session_expire")
}

model uploaded_documents {
  id             Int      @id @default(autoincrement())
  user_id        Int
  original_name  String
  file_type      String
  file_size      Int?
  status         String   @default("uploaded")
  document_type  String?
  extracted_text String?
  created_at     DateTime @default(now()) @db.Timestamp(6)
  users          users    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model user_profiles {
  id                   Int      @id @default(autoincrement())
  user_id              Int      @unique(map: "user_profiles_user_id_unique")
  business_type        String?
  province             String?  @default("ON")
  income_range         String?
  onboarding_completed Boolean  @default(false)
  created_at           DateTime @default(now()) @db.Timestamp(6)
  first_name           String?
  last_name            String?
  users                users    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "user_profiles_user_id_users_id_fk")
}

model users {
  id                     Int                    @id @default(autoincrement())
  email                  String                 @unique(map: "users_email_unique")
  password_hash          String?
  created_at             DateTime               @default(now()) @db.Timestamp(6)
  google_id              String?                @unique(map: "users_google_id_unique")
  stripe_customer_id     String?                @unique
  stripe_subscription_id String?
  subscription_status    String                 @default("free")
  plan_type              String?
  analytics_events       analytics_events[]
  income_strategies      income_strategies[]
  net_worth_items        net_worth_items[]
  net_worth_statements   net_worth_statements[]
  reports                reports[]
  scenarios              scenarios[]
  uploaded_documents     uploaded_documents[]
  user_profiles          user_profiles?
}

model waitlist_emails {
  id         Int      @id @default(autoincrement())
  email      String   @unique(map: "waitlist_emails_email_unique")
  source     String   @default("landing")
  created_at DateTime @default(now()) @db.Timestamp(6)
}

// ── UUID-based Prisma-native models ───────────────────────────────────────────
// These are new tables managed by Prisma, separate from the legacy
// Drizzle-managed integer-keyed tables above.

model User {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String       @unique
  display_name String?
  avatar_url   String?
  created_at   DateTime     @default(now()) @db.Timestamptz(6)
  updated_at   DateTime     @default(now()) @updatedAt @db.Timestamptz(6)

  profile               UserProfile?
  subscription          Subscription?
  activity              ActivityLog[]
  notifications         Notification[]
  uploaded_documents    UploadedDocument[]
  ai_extractions        AIExtraction[]
  annotations           Annotation[]
  net_worth_statements  NetWorthStatement[]
  net_worth_items       NetWorthItem[]
  income_strategies     IncomeStrategy[]
  reports               Report[]

  @@map("app_users")
}

model UserProfile {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @unique @db.Uuid
  first_name String?
  last_name  String?
  phone      String?
  timezone   String   @default("America/Toronto")
  locale     String   @default("en-CA")
  province   String   @default("ON")
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("app_user_profiles")
}

model Subscription {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                String    @unique @db.Uuid
  plan                   String    @default("free")
  status                 String    @default("active")
  stripe_customer_id     String?   @unique
  stripe_subscription_id String?   @unique
  current_period_start   DateTime? @db.Timestamptz(6)
  current_period_end     DateTime? @db.Timestamptz(6)
  cancelled_at           DateTime? @db.Timestamptz(6)
  created_at             DateTime  @default(now()) @db.Timestamptz(6)
  updated_at             DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  user                   User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model ActivityLog {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String   @db.Uuid
  action        String
  resource_type String?
  resource_id   String?
  metadata      Json?
  ip_address    String?
  user_agent    String?
  created_at    DateTime @default(now()) @db.Timestamptz(6)

  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([created_at(sort: Desc)])
  @@map("activity_logs")
}

model Notification {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  type       String
  title      String
  body       String?
  read       Boolean   @default(false)
  read_at    DateTime? @db.Timestamptz(6)
  action_url String?
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([user_id, read])
  @@map("notifications")
}

// ── Document models ───────────────────────────────────────────────────────────

model UploadedDocument {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String    @db.Uuid
  file_name      String
  file_type      String
  file_size      Int?
  storage_path   String?
  status         String    @default("pending")
  document_type  String?
  created_at     DateTime  @default(now()) @db.Timestamptz(6)
  updated_at     DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  user                 User                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  extractions          AIExtraction[]
  annotations          Annotation[]
  net_worth_statements NetWorthStatement[]
  income_strategies    IncomeStrategy[]
  reports              Report[]

  @@index([user_id])
  @@map("doc_uploaded_documents")
}

model AIExtraction {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  document_id      String    @db.Uuid
  user_id          String    @db.Uuid
  model            String    @default("gpt-4o")
  raw_json         Json?
  confidence_score Float?
  status           String    @default("pending")
  error            String?
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  document         UploadedDocument  @relation(fields: [document_id], references: [id], onDelete: Cascade)
  user             User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  annotations      Annotation[]
  net_worth_items  NetWorthItem[]

  @@index([document_id])
  @@index([user_id])
  @@map("doc_ai_extractions")
}

model Annotation {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  document_id      String    @db.Uuid
  extraction_id    String?   @db.Uuid
  user_id          String    @db.Uuid
  field_key        String
  original_value   String?
  corrected_value  String
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  document         UploadedDocument  @relation(fields: [document_id], references: [id], onDelete: Cascade)
  extraction       AIExtraction?     @relation(fields: [extraction_id], references: [id], onDelete: SetNull)
  user             User              @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([document_id])
  @@index([user_id])
  @@map("doc_annotations")
}

// ── Financial models ──────────────────────────────────────────────────────────

model NetWorthStatement {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String    @db.Uuid
  title             String    @default("My Net Worth")
  as_of_date        DateTime? @db.Date
  total_assets      Int       @default(0)
  total_liabilities Int       @default(0)
  net_worth         Int       @default(0)
  document_id       String?   @db.Uuid
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  updated_at        DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  user             User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  document         UploadedDocument? @relation(fields: [document_id], references: [id], onDelete: SetNull)
  items            NetWorthItem[]
  reports          Report[]

  @@index([user_id])
  @@map("fw_net_worth_statements")
}

model NetWorthItem {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  statement_id  String    @db.Uuid
  user_id       String    @db.Uuid
  type          String
  category      String
  name          String
  amount        Int       @default(0)
  notes         String?
  extraction_id String?   @db.Uuid
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  updated_at    DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  statement     NetWorthStatement  @relation(fields: [statement_id], references: [id], onDelete: Cascade)
  user          User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  extraction    AIExtraction?      @relation(fields: [extraction_id], references: [id], onDelete: SetNull)

  @@index([statement_id])
  @@index([user_id])
  @@map("fw_net_worth_items")
}

model IncomeStrategy {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                 String    @db.Uuid
  title                   String
  province                String    @default("ON")
  corporate_profit        Int       @default(0)
  desired_cash_withdrawal Int       @default(0)
  grip_balance            Int?
  wants_cpp_rrsp          String?
  prefer_simple           Boolean   @default(false)
  salary_recommendation   Int?
  dividend_recommendation Int?
  blended_note            String?
  document_id             String?   @db.Uuid
  created_at              DateTime  @default(now()) @db.Timestamptz(6)
  updated_at              DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  user             User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  document         UploadedDocument? @relation(fields: [document_id], references: [id], onDelete: SetNull)
  reports          Report[]

  @@index([user_id])
  @@map("fw_income_strategies")
}

model Report {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String    @db.Uuid
  report_type    String
  title          String
  status         String    @default("generated")
  reference_type String?
  reference_id   String?   @db.Uuid
  statement_id   String?   @db.Uuid
  strategy_id    String?   @db.Uuid
  document_id    String?   @db.Uuid
  created_at     DateTime  @default(now()) @db.Timestamptz(6)
  updated_at     DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  user       User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  statement  NetWorthStatement? @relation(fields: [statement_id], references: [id], onDelete: SetNull)
  strategy   IncomeStrategy?    @relation(fields: [strategy_id], references: [id], onDelete: SetNull)
  document   UploadedDocument?  @relation(fields: [document_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@map("fw_reports")
}

